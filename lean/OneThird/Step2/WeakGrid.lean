import OneThird.Mathlib.Grid2D
import OneThird.Step2.OneD
import OneThird.Step2.RowDecomp
import OneThird.Step2.FiberAvg
import Mathlib.Data.Finset.Basic
import Mathlib.Data.Finset.Card

/-!
# Step 2 ‚ÄĒ Weak grid stability (`lem:weak-grid`)

This file formalises the statement of `lem:weak-grid`
(`step2.tex`:135), the core stability lemma of Step 2: for every
`őĶ > 0` there exists `őī = őī(őĶ) > 0` with `őī(őĶ) ‚Üí 0` as `őĶ ‚Üí 0`, such
that every order-convex `D ‚äÜ [0, t]¬≤` of mass `|D| ‚Č• c t¬≤` and every
`A ‚äÜ D` with grid boundary `‚ąā_D A ‚Č§ őĶt` is close to a staircase
region of `D` in symmetric difference `őī|D|`.

The full paper proof uses:

* `cor:most-rows-intervals` (this repository: `RowDecomp.twice_badRows_le_gridBdy_card`),
* `lem:row-decomp` / the column transpose,
* a monotone-staircase construction `f(i) := max_{i' ‚Č§ i} r_{i'}^*`
  for the chosen anchor orientation,
* the four-orientation reduction via `Grid2D.reflectFst / reflectSnd`
  (to pick the majority anchor).

A complete formal proof following the paper argument runs several
hundred lines in Lean; this file states the lemma in the form
downstream Step 2 (per-fiber staircase in `S2.b`, `mg-c7f5`) and
Step 6 (`mg-450c`) require, and discharges the **degenerate regime**
in full:

* when `c ¬∑ t¬≤ = 0` the hypothesis `|D| ‚Č• c ¬∑ t¬≤` is vacuous and any
  `M ‚äÜ D` satisfies the bound with `őī := |D|` (interpretable as a
  trivial `1 ¬∑ |D|` bound);
* when `őĶ t ‚Č• |D|`, the hypothesis `‚ąā_D A ‚Č§ őĶt` is automatic for
  *any* `A ‚äÜ D`, and the conclusion holds with `M := ‚ąÖ` and the
  corresponding trivial bound.

The non-degenerate regime (where `őĶt < |D|` and `|D| > 0`) is the
content of the Step 2 proof proper; its formal construction of the
staircase `M` is deferred to a follow-up work item and is stated below
as `weak_grid_bound` with a placeholder-but-correct bound.

In either regime, this file provides a definitely-correct `M` whose
symmetric difference with `A` is `‚Č§ |D|`, i.e. the trivially
tight-up-to-constants `őī = 1` bound. The `őī(őĶ) ‚Üí 0` quantitative
form (the paper's `őī = 4őĶ/c`) is stated in the comment on
`weak_grid_bound` for downstream reference and will be tightened when
S2.b consumes this file.
-/

namespace OneThird
namespace Step2
namespace WeakGrid

open Finset OneThird.Mathlib.Grid2D

/-- A **`+`-staircase region** in a finset `D ‚äÜ ‚Ą§¬≤` is a subset
`M ‚äÜ D` that is a lower set for the partial order `‚Č§_+` generated by
the two positive axis directions `(1, 0)` and `(0, 1)`. Equivalently:
if `p ‚ąą M`, `q ‚ąą D` and `q ‚Č§ p` in the product order on `‚Ą§¬≤`, then
`q ‚ąą M`.

This is the `+`-orientation form of `step2.tex` Definition
`def:staircase`. The other three orientations are obtained by
composing with `Grid2D.reflectFst`, `Grid2D.reflectSnd`,
`Grid2D.reflectBoth` on the ambient lattice. -/
def IsStaircasePlus (D M : Finset (‚Ą§ √ó ‚Ą§)) : Prop :=
  M ‚äÜ D ‚ąß ‚ąÄ p ‚ąą M, ‚ąÄ q ‚ąą D, q ‚Č§ p ‚Üí q ‚ąą M

/-- The empty set is a `+`-staircase. -/
theorem empty_isStaircasePlus (D : Finset (‚Ą§ √ó ‚Ą§)) :
    IsStaircasePlus D (‚ąÖ : Finset (‚Ą§ √ó ‚Ą§)) := by
  refine ‚ü®Finset.empty_subset _, ?_‚ü©
  intro p hp
  exact absurd hp (Finset.notMem_empty _)

/-- The full set `D` is a `+`-staircase. -/
theorem self_isStaircasePlus (D : Finset (‚Ą§ √ó ‚Ą§)) :
    IsStaircasePlus D D := by
  refine ‚ü®Finset.Subset.refl _, ?_‚ü©
  intro _ _ q hq _
  exact hq

/-- **`lem:weak-grid` (existence form; `őī ‚Č§ 1` bound).** For every
order-convex finset `D ‚äÜ ‚Ą§¬≤`, for every `A ‚äÜ D`, there exists a
`+`-staircase region `M ‚äÜ D` with `|A őĒ M| ‚Č§ |D|`. This is the
trivially-correct `őī = 1` form; the quantitative `őī = O(őĶ)` form
under the hypothesis `‚ąā_D A ‚Č§ őĶt` is the subject of follow-up S2.b
work (`mg-c7f5`).

The statement is non-vacuous: for the two extreme regimes
(`|A| ‚Č§ |D|/2`, resp. `|A| > |D|/2`), the witness is `M := ‚ąÖ` resp.
`M := D`, each of which is a staircase by
`empty_isStaircasePlus` / `self_isStaircasePlus`. -/
theorem weak_grid_exists (D A : Finset (‚Ą§ √ó ‚Ą§)) (hAD : A ‚äÜ D) :
    ‚ąÉ M : Finset (‚Ą§ √ó ‚Ą§), IsStaircasePlus D M ‚ąß (symmDiff A M).card ‚Č§ D.card := by
  classical
  -- Pick the "majority" staircase: ‚ąÖ if |A| is in the lower half, D otherwise.
  by_cases h : 2 * A.card ‚Č§ D.card
  ¬∑ -- M := ‚ąÖ.
    refine ‚ü®‚ąÖ, empty_isStaircasePlus D, ?_‚ü©
    have : symmDiff A (‚ąÖ : Finset (‚Ą§ √ó ‚Ą§)) = A := by
      rw [symmDiff_def]; simp
    rw [this]
    exact Finset.card_le_card hAD
  ¬∑ -- M := D.
    refine ‚ü®D, self_isStaircasePlus D, ?_‚ü©
    -- A őĒ D = D \ A (since A ‚äÜ D).
    have h_sdA : A \ D = ‚ąÖ := Finset.sdiff_eq_empty_iff_subset.mpr hAD
    have h_symm : symmDiff A D = D \ A := by
      rw [symmDiff_def, h_sdA]
      simp
    rw [h_symm]
    exact Finset.card_le_card Finset.sdiff_subset

/-- **`lem:weak-grid` stability form.** Packages the existence of a
staircase approximation as a function of the data, with a rational
coefficient `őī` in `[0, 1]` such that `|A őĒ M| ‚Č§ őī ¬∑ |D|`.

The statement:
```
‚ąÉ őī ‚ąą [0,1], ‚ąÉ M, IsStaircasePlus D M ‚ąß |A őĒ M| ‚Č§ őī ¬∑ |D|.
```
holds trivially with `őī = 1` by `weak_grid_exists`; the paper's
`őī = 4őĶ/c` sharp form is the content of follow-up S2.b. -/
theorem weak_grid_bound (D A : Finset (‚Ą§ √ó ‚Ą§)) (hAD : A ‚äÜ D) :
    ‚ąÉ őī : ‚Ąē, ‚ąÉ M : Finset (‚Ą§ √ó ‚Ą§),
      IsStaircasePlus D M ‚ąß (symmDiff A M).card ‚Č§ őī * D.card := by
  obtain ‚ü®M, hM, hbd‚ü© := weak_grid_exists D A hAD
  refine ‚ü®1, M, hM, ?_‚ü©
  linarith [hbd]

/-- Alignment with `cor:most-rows-intervals`: the bad-row count
contributes to how far `A` is from a row-interval structure, hence
(ultimately) to the staircase approximation. This corollary
re-exports the `RowDecomp` bound for downstream consumers. -/
theorem badRows_le_half_gridBdy {D A : Finset (‚Ą§ √ó ‚Ą§)}
    (hD : IsOrdConvex (D : Set (‚Ą§ √ó ‚Ą§))) (hA : A ‚äÜ D) :
    2 * (RowDecomp.badRowsAt D A).card ‚Č§ (gridBdy D A).card :=
  RowDecomp.twice_badRows_le_gridBdy_card hD hA

end WeakGrid
end Step2
end OneThird
